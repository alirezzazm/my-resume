# ─────────────────────────────────────────────
# DATABASE — SQLite by default (file در data/portfolio.db)
# برای Postgres: DATABASE_URL="postgresql://user:pass@host:5432/dbname"
# ─────────────────────────────────────────────
DATABASE_URL="file:./data/portfolio.db"

# ─────────────────────────────────────────────
# ADMIN AUTH
# ─────────────────────────────────────────────
# این secret باید رشته‌ی تصادفی حداقل ۳۲ کاراکتر باشد.
# بسازش با: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="CHANGE_ME_TO_RANDOM_STRING_AT_LEAST_32_CHARS_LONG"

# پسورد ادمین اولیه (با npm run admin:create می‌توانید کاربر بسازید)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="changeme"

# ─────────────────────────────────────────────
# SMTP — برای فرم تماس
# ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
CONTACT_EMAIL=alireza.zamani7745@gmail.com

# ─────────────────────────────────────────────
# Site
# ─────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_NAME="Alireza Zamani | Portfolio"
